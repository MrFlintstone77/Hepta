{
  "name": "hepta-design-system",
  "private": true,
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "dev": "npm run dev -w docs",
    "build": "npm run build:tokens && npm run build:components && npm run build -w docs",
    "build:tokens": "npm run build -w @hepta/tokens",
    "build:components": "npm run build -w @hepta/components",
    "preview": "npm run preview -w docs"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "shadcn": "^4.0.0"
  },
  "overrides": {
    "tailwindcss": "3.4.19"
  }
}
